# Copy this file to .env and adjust before running `docker compose up`

# --- Auth (chat-ui, orchestrator API, MCP server) ---
# THOS ships with weak, well-known defaults so a first `docker compose up`
# works with zero setup — but every one of these gates a network port with
# real capability behind it (running hunts, reading every report, calling
# SOC tools directly). Generate real values before this stack is reachable
# by anyone but you, e.g.:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=thos_change_me_mcp_token
ORCHESTRATOR_API_KEY=thos_change_me_orchestrator_key
# Single hunter login (used only if CHATUI_USERS below is left blank):
CHATUI_USERNAME=analyst
CHATUI_PASSWORD=thos_change_me
# For more than one hunter, set CHATUI_USERS instead — comma-separated
# user:pass pairs, e.g.:
CHATUI_USERS=hunter:change_me,bob:pw2,carol:pw3
# When set, this takes precedence over CHATUI_USERNAME/CHATUI_PASSWORD.
CHATUI_USERS=
# Redis had no auth at all before — now requires this password.
REDIS_PASSWORD=thos_change_me_redis

# --- Ollama ---
OLLAMA_MODEL=qwen3:4b
# Larger reasoning quality: qwen3:4b (needs more RAM/VRAM)
# --- Agentic model fleet (all endpoints must be on-prem) ---
# Unset values safely inherit OLLAMA_HOST + OLLAMA_MODEL above. Set a model
# and optional host per tier to route specialist agents to separate Ollama or
# vLLM instances. Suggested names are comments, not automatic downloads.
# THOS_MODEL_FAST=qwen3:8b
# THOS_MODEL_REASONING=qwen3:32b
# THOS_MODEL_VERIFIER=deepseek-r1:32b
# THOS_MODEL_CODING=qwen3-coder:30b
# THOS_MODEL_GUARD=phi4-mini
# THOS_OLLAMA_FAST_HOST=http://ollama:11434
# THOS_OLLAMA_REASONING_HOST=http://ollama:11434
# THOS_OLLAMA_VERIFIER_HOST=http://ollama:11434
# THOS_OLLAMA_CODING_HOST=http://ollama:11434
# THOS_OLLAMA_GUARD_HOST=http://ollama:11434

# --- Postgres (audit trail / hunt state) ---
POSTGRES_USER=thos
POSTGRES_PASSWORD=thos_change_me
POSTGRES_DB=thos_audit

# --- SIEM credentials (Phase 2 — leave blank for Phase 1 mock mode) ---
SIEM_TYPE=mock
# SIEM_TYPE=logrhythm | splunk | qradar | folder
# "folder": hunt against a local directory of log files instead of a
# live SIEM API. Supported file types: .evtx .log .syslog .csv .cef
# .json .ecs .ndjson .jsonl .xml .txt .pcap .pcapng
# The folder itself is chosen per-hunt from the chat UI ("Log folder
# path"), but LOG_SOURCE_DIR sets the default / where uploads land.
LOG_SOURCE_DIR=/data/log_sources
# Any folder path passed in for "folder" mode must resolve inside one of
# these roots (os.pathsep-separated for multiple), or the request is
# rejected — without this, log_source_path accepted any container-
# readable path with no auth in front of it. Defaults to LOG_SOURCE_DIR
# if unset.
# LOG_SOURCE_ALLOWED_ROOTS=/data/log_sources

LOGRHYTHM_BASE_URL=
LOGRHYTHM_API_TOKEN=
# Optional tuning (defaults shown) — see services/siem/logrhythm.py
# LOGRHYTHM_VERIFY_SSL=1
# LOGRHYTHM_LOOKBACK_MINUTES=1440
# LOGRHYTHM_POLL_INTERVAL_SECONDS=2
# LOGRHYTHM_POLL_TIMEOUT_SECONDS=60
# LOGRHYTHM_SEARCH_EVENTS=0

SPLUNK_BASE_URL=
SPLUNK_TOKEN=
# Optional tuning (defaults shown) — see services/siem/splunk.py
# SPLUNK_VERIFY_SSL=1
# SPLUNK_LOOKBACK=-24h
# SPLUNK_POLL_INTERVAL_SECONDS=2
# SPLUNK_POLL_TIMEOUT_SECONDS=60

QRADAR_BASE_URL=
QRADAR_TOKEN=
# Optional tuning (defaults shown) — see services/siem/qradar.py
# QRADAR_VERIFY_SSL=1
# QRADAR_API_VERSION=20.0
# QRADAR_LOOKBACK_MINUTES=1440
# QRADAR_POLL_INTERVAL_SECONDS=2
# QRADAR_POLL_TIMEOUT_SECONDS=60

# WAZUH
WAZUH_INDEXER_URL=https://host.docker.internal:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_VERIFY_SSL=0
WAZUH_CA_BUNDLE=
WAZUH_INDEX_SOURCE=both
WAZUH_LOOKBACK_MINUTES=1440
WAZUH_REQUEST_TIMEOUT_SECONDS=30
WAZUH_MAX_RESULTS=1000

# --- Logging ---
# Structured JSON logs on stdout for mcp/orchestrator/chat-ui — one of
# DEBUG/INFO/WARNING/ERROR. See services/observability/logging_config.py.
LOG_LEVEL=INFO
